---
import { RevealOnScroll } from '@/components/shared/RevealOnScroll';
import { fadeUp, stagger } from '@/lib/animations';
import { config } from '@/lib/config';
import { MapPin } from 'lucide-react';
---

<section class="py-16 md:py-24 bg-slate-50 border-t border-slate-200/50" id="einzugsgebiet">
  <div class="max-w-6xl mx-auto px-4 md:px-8 text-center">
    <RevealOnScroll client:load variants={fadeUp}>
      <div class="inline-flex items-center gap-2 text-primary font-semibold mb-4 bg-primary-lighter px-3 py-1 rounded-full text-sm">
        <MapPin class="w-4 h-4" />
        <span>Regional verwurzelt</span>
      </div>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-slate-900 mb-6">Wir sind für Sie da – in {config.company.region}.</h2>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto mb-10 leading-relaxed">
        Mit unserem zentralen Sitz in {config.company.address.city} decken wir einen Service-Radius von ca. {config.company.serviceRadius} ab. So garantieren wir schnelle Anfahrtswege und rechtzeitige Notdienst-Einsätze.
      </p>
    </RevealOnScroll>

    <RevealOnScroll client:load variants={stagger}>
      <div class="flex flex-wrap justify-center gap-3 md:gap-4 max-w-4xl mx-auto">
        {config.serviceLocations.map((location) => (
          <RevealOnScroll client:load variants={fadeUp}>
            <div class="bg-white border text-sm md:text-base border-slate-200 text-slate-700 px-5 py-2 md:py-3 rounded-full font-medium shadow-sm hover:border-primary/40 hover:text-primary transition-colors cursor-default whitespace-nowrap">
              {location}
            </div>
          </RevealOnScroll>
        ))}
      </div>
    </RevealOnScroll>
    
    {config.features.google_maps && (
      <div class="mt-16 w-full h-[400px] bg-slate-200 border-2 border-dashed border-slate-300 rounded-sm flex items-center justify-center text-slate-500 text-lg font-medium">
        Google Maps Integration (Hier Map-Embed platzieren)
      </div>
    )}
  </div>
</section>
