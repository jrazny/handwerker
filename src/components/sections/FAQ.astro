---
import { RevealOnScroll } from '@/components/shared/RevealOnScroll';
import { fadeUp } from '@/lib/animations';
import { FAQAccordion } from './FAQAccordion';
---

<section class="py-16 md:py-24 bg-white" id="faq">
  <div class="max-w-3xl mx-auto px-4 md:px-8">
    <RevealOnScroll client:load variants={fadeUp} className="mb-10 text-center md:text-left">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-slate-900 mb-4">Häufig gestellte Fragen</h2>
      <p class="text-lg text-slate-600 leading-relaxed">Antworten auf die wichtigsten Fragen rund um unsere Leistungen und Abläufe.</p>
    </RevealOnScroll>

    <RevealOnScroll client:load variants={fadeUp}>
      <FAQAccordion client:load />
    </RevealOnScroll>
  </div>
</section>
