---
import { RevealOnScroll } from '@/components/shared/RevealOnScroll';
import { Button } from '@/components/ui/button';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { services } from '@/lib/services-data';
import { Flame, ShowerHead, Zap, Siren, Sun, Wrench } from 'lucide-react';
import { fadeUp, stagger } from '@/lib/animations';

const iconMap: Record<string, any> = {
  Flame,
  ShowerHead,
  Zap,
  Siren,
  Sun,
};
---

<section class="py-16 md:py-24 bg-white" id="leistungen">
  <div class="max-w-6xl mx-auto px-4 md:px-8">
    <RevealOnScroll client:load variants={fadeUp} className="text-center mb-12 lg:mb-16">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-slate-900 mb-4">Unsere Leistungen</h2>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto leading-relaxed">
        Professionelle Handwerksarbeit aus einer Hand. Wir sind Ihr zuverlässiger Partner für funktionierende Haustechnik.
      </p>
    </RevealOnScroll>

    <RevealOnScroll client:load variants={stagger}>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        {services.map((service) => {
          const IconComp = iconMap[service.icon] || Wrench;
          
          return (
            <RevealOnScroll client:load variants={fadeUp} className="h-full">
              <Card className="border border-slate-200 bg-white p-6 hover:border-primary/30 transition-colors group h-full flex flex-col rounded-none md:rounded-sm shadow-none">
                <CardHeader className="p-0 mb-5">
                  <div class="w-12 h-12 flex items-center justify-center bg-primary-lighter rounded-md text-primary mb-5">
                    <IconComp className="w-6 h-6" />
                  </div>
                  <CardTitle className="text-xl md:text-2xl font-bold tracking-tight text-slate-900">{service.titel}</CardTitle>
                </CardHeader>
                <CardContent className="p-0 flex-grow flex flex-col">
                  <p class="text-slate-600 leading-relaxed mb-6 flex-grow">{service.beschreibung}</p>
                  <Button asChild variant="ghost" className="p-0 text-primary group-hover:underline justify-start font-semibold">
                    <a href={`/leistungen/${service.slug}`}>Mehr erfahren &rarr;</a>
                  </Button>
                </CardContent>
              </Card>
            </RevealOnScroll>
          );
        })}
      </div>
    </RevealOnScroll>
  </div>
</section>
