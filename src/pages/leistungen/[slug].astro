---
import Layout from '@/layouts/Layout.astro';
import { services } from '@/lib/services-data';
import { Button } from '@/components/ui/button';
import { ShieldCheck, ArrowRight, CheckCircle2 } from 'lucide-react';
import { RevealOnScroll } from '@/components/shared/RevealOnScroll';
import { fadeUp, stagger, fadeLeft, fadeRight } from '@/lib/animations';

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
---

<Layout title={service.seo_title} description={service.seo_description}>
  {/* Mini Hero */}
  <section class="bg-primary text-white py-20 px-4 md:px-8 border-b-4 border-accent">
    <div class="max-w-4xl mx-auto text-center">
      <RevealOnScroll client:load variants={fadeUp}>
        <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-6">{service.titel}</h1>
        <p class="text-xl text-primary-lighter max-w-2xl mx-auto leading-relaxed">{service.kurz}</p>
      </RevealOnScroll>
    </div>
  </section>

  <div class="bg-white py-16 md:py-24">
    <div class="max-w-6xl mx-auto px-4 md:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
        
        {/* Main Content */}
        <div class="lg:col-span-8 flex flex-col gap-12">
          {/* Problemstellung */}
          <RevealOnScroll client:load variants={fadeUp}>
            <div class="bg-slate-50 border border-slate-200 p-8 rounded-sm">
              <h2 class="text-2xl font-bold tracking-tight text-slate-900 mb-6">Kennen Sie das?</h2>
              <ul class="space-y-4">
                {service.kundenprobleme.map((problem) => (
                  <li class="flex items-start gap-3 text-slate-700">
                    <ArrowRight class="w-5 h-5 text-accent shrink-0 mt-0.5" />
                    <span class="leading-relaxed text-lg">{problem}</span>
                  </li>
                ))}
              </ul>
            </div>
          </RevealOnScroll>

          {/* Lösung */}
          <RevealOnScroll client:load variants={fadeUp}>
            <h2 class="text-3xl font-bold tracking-tight text-slate-900 mb-6">Unsere Lösung für Sie</h2>
            <div class="prose prose-lg prose-slate text-slate-600 max-w-none leading-relaxed">
              <p>{service.beschreibung}</p>
            </div>
          </RevealOnScroll>

          {/* Vorteile Cards */}
          <RevealOnScroll client:load variants={stagger}>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              {service.vorteile.map((vorteil) => (
                <RevealOnScroll client:load variants={fadeUp}>
                  <div class="bg-white border text-center border-slate-200 p-6 rounded-sm shadow-sm h-full flex flex-col">
                    <div class="w-12 h-12 bg-primary-lighter text-primary rounded-full flex items-center justify-center mx-auto mb-4">
                      <ShieldCheck class="w-6 h-6" />
                    </div>
                    <h3 class="font-bold text-lg text-slate-900 mb-3">{vorteil.titel}</h3>
                    <p class="text-slate-600 text-sm leading-relaxed">{vorteil.text}</p>
                  </div>
                </RevealOnScroll>
              ))}
            </div>
          </RevealOnScroll>
        </div>

        {/* Sidebar */}
        <div class="lg:col-span-4 sticky top-28">
          <RevealOnScroll client:load variants={fadeRight}>
            <div class="bg-slate-900 text-white p-8 rounded-sm shadow-md">
              <h3 class="text-xl font-bold tracking-tight mb-4">Bereit für Ihr Projekt?</h3>
              <p class="text-slate-300 mb-8 leading-relaxed">
                Profitieren Sie von unserer Erfahrung im Bereich <strong class="text-white font-semibold">{service.titel}</strong>. Wir beraten Sie herstellerunabhängig.
              </p>
              
              <div class="flex flex-col gap-4">
                <Button asChild size="lg" className="bg-accent hover:bg-accent-light text-white w-full h-14 rounded-md">
                  <a href={`/kontakt?service=${service.slug}`}>Unverbindliche Anfrage</a>
                </Button>
                <div class="text-center text-sm text-slate-400 my-2">oder rufen Sie uns an</div>
                <Button asChild size="lg" variant="outline" className="border-2 border-white/20 bg-white/10 hover:bg-white hover:text-primary text-white w-full h-14 rounded-md">
                  <a href="/kontakt">Jetzt anrufen</a>
                </Button>
              </div>
            </div>
          </RevealOnScroll>
          
          <RevealOnScroll client:load variants={fadeUp} className="mt-8">
            <div class="bg-primary-lighter p-6 rounded-sm border border-primary/10">
              <div class="flex items-center gap-3 mb-4">
                <CheckCircle2 class="w-6 h-6 text-primary" />
                <h4 class="font-bold text-slate-900">Unser Versprechen</h4>
              </div>
              <ul class="space-y-2 text-slate-700 text-sm">
                <li>&bull; Transparente Festpreise</li>
                <li>&bull; Pünktliche Ausführung</li>
                <li>&bull; Erfahrene Handwerker</li>
              </ul>
            </div>
          </RevealOnScroll>
        </div>
      </div>
    </div>
  </div>
</Layout>
